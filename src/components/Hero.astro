---
export interface TerminalFrame {
  lines: string[];
  delay: number;
}
const frames: TerminalFrame[] = [
  {
    lines: [
      '<span class="token-prompt">$</span> <span class="token-command">cognitiveos boot</span>',
      '<span class="token-output">[██████████] 100% Alpine Linux ready</span>',
      '<span class="token-success">✓</span> <span class="token-output">cognitiveosd started (PID 42)</span>',
    ],
    delay: 1500,
  },
  {
    lines: [
      '<span class="token-output">CognitiveOS v0.1.0 — waiting for intent...</span>',
      '',
      '<span class="token-prompt">></span> <span class="token-string">"show me YouTube cat videos"</span>',
    ],
    delay: 1500,
  },
  {
    lines: [
      '<span class="token-success">✓</span> <span class="token-output">Intent parsed: search youtube for "cat videos"</span>',
      '<span class="token-success">✓</span> <span class="token-output">Opening YouTube → playing top result</span>',
      '<span class="token-success">✓</span> <span class="token-keyword">AI: "Displaying funny cat compilation 2024"</span>',
    ],
    delay: 2000,
  },
];
---
<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Background subtle grid -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#00e5cc 1px, transparent 1px), linear-gradient(90deg, #00e5cc 1px, transparent 1px); background-size: 60px 60px;"></div>

  <!-- Soft cyan glow blob -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-cyan/5 blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
    <span class="inline-block font-mono text-[10px] tracking-[0.3em] text-cyan/70 uppercase mb-8 border border-cyan/20 px-4 py-1.5 rounded-full">AI-Native Operating System</span>

    <h1 class="text-4xl sm:text-5xl md:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
      <span class="text-white">The human sets goals.</span><br />
      <span class="text-cyan">The AI operates</span><br />
      <span class="text-white">the machine.</span>
    </h1>

    <p class="text-neutral-400 text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed mb-8">
      No apps. No browsers. No permission dialogs. Just speak your intent and the AI acts — directly on the hardware.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a href="https://github.com/CognitiveOS-Project" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-cyan text-bg font-semibold px-8 py-3.5 rounded-lg hover:bg-cyan/90 transition-all">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
      <a href="#architecture" class="inline-flex items-center gap-2 border border-neutral-600 text-neutral-200 font-medium px-8 py-3.5 rounded-lg hover:border-cyan/50 hover:text-cyan transition-all">
        Explore architecture
      </a>
    </div>

    <!-- Terminal window -->
    <div class="max-w-xl mx-auto">
      <div class="bg-black/80 border border-border rounded-xl overflow-hidden shadow-2xl">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border bg-muted/50">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
          <span class="text-xs text-neutral-500 font-mono ml-3">cognitiveos — terminal</span>
        </div>
        <div id="terminal" class="p-5 font-mono text-sm leading-relaxed min-h-[120px] text-left whitespace-pre-wrap">
          <span class="token-prompt">$</span> <span class="token-command">cognitiveos boot</span>
          <span class="token-output block">[██████████] 100% Alpine Linux ready</span>
          <span class="token-success">✓</span> <span class="token-output">cognitiveosd started (PID 42)</span>
          <span class="animate-blink float-none">▊</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const frames = [
    [
      '<span class="token-prompt">$</span> <span class="token-command">cognitiveos boot</span>\n<span class="token-output">[██████████] 100% Alpine Linux ready</span>\n<span class="token-success">✓</span> <span class="token-output">cognitiveosd started (PID 42)</span>',
    ],
    [
      '<span class="token-output">CognitiveOS v0.1.0 — waiting for intent...</span>\n\n<span class="token-prompt">></span> <span class="token-string">"show me YouTube cat videos"</span>',
    ],
    [
      '<span class="token-success">✓</span> <span class="token-output">Intent parsed: search youtube for "cat videos"</span>\n<span class="token-success">✓</span> <span class="token-output">Opening YouTube → playing top result</span>\n<span class="token-success">✓</span> <span class="token-keyword">AI: "Displaying funny cat compilation 2024"</span>',
    ],
  ];

  const terminal = document.getElementById('terminal');
  let frameIndex = 0;
  let charIndex = 0;
  let isTyping = false;
  let timeoutId = null;

  function typeFrame(frameIdx) {
    const text = frames[frameIdx][0];
    charIndex = 0;
    isTyping = true;
    terminal.innerHTML = '';

    function typeChar() {
      if (charIndex < text.length) {
        const nextChar = text[charIndex];
        terminal.innerHTML = text.slice(0, charIndex + 1) + '<span class="animate-blink">▊</span>';
        charIndex++;
        const delay = nextChar === '\n' ? 80 : Math.random() * 30 + 20;
        timeoutId = setTimeout(typeChar, delay);
      } else {
        isTyping = false;
        terminal.innerHTML = text + '<span class="animate-blink">▊</span>';
        timeoutId = setTimeout(nextFrame, 2500);
      }
    }
    typeChar();
  }

  function nextFrame() {
    frameIndex = (frameIndex + 1) % frames.length;
    typeFrame(frameIndex);
  }

  typeFrame(0);
</script>
