---
<footer class="border-t border-border py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid sm:grid-cols-3 gap-8 font-mono text-xs">
      <div>
        <div class="flex items-center gap-2 mb-3">
          <span class="w-2 h-2 rounded-full bg-cyan animate-pulse-dot"></span>
          <span class="font-bold text-sm tracking-widest text-white">COGNITIVEOS</span>
        </div>
        <p class="text-neutral-500 leading-relaxed">MIT License</p>
        <p class="text-neutral-500">Open source from the ground up.</p>
      </div>
      <div>
        <p class="text-neutral-400 mb-3 tracking-wider uppercase">Author</p>
        <a href="https://github.com/jeanmachuca" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-cyan transition-colors block">Jean Machuca</a>
        <a href="https://github.com/CognitiveOS-Project" target="_blank" rel="noopener noreferrer" class="text-neutral-500 hover:text-cyan transition-colors block mt-1">GitHub Organization</a>
      </div>
      <div class="text-neutral-500">
        <p class="text-neutral-400 mb-3 tracking-wider uppercase">Info</p>
        <p>&copy; {new Date().getFullYear()} CognitiveOS Project</p>
        <p class="mt-1">Built with Alpine Linux</p>
      </div>
    </div>
  </div>
</footer>
